{
  "name": "tensorlake",
  "version": "0.5.85",
  "description": "TensorLake SDK for applications, sandboxes, and cloud services",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tensorlake-deploy": "./bin/tensorlake-deploy.cjs",
    "tensorlake-create-sandbox-image": "./bin/tensorlake-create-sandbox-image.cjs",
    "tensorlake-import-sandbox-image": "./bin/tensorlake-import-sandbox-image.cjs",
    "function-executor": "./bin/function-executor.cjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "bin",
    "lib"
  ],
  "scripts": {
    "build:sdk": "tsup",
    "build:native": "node ./scripts/build-native.mjs",
    "build": "npm run build:sdk && npm run build:native",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude tests/integration.test.ts",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "tensorlake",
    "sandbox",
    "cloud",
    "sdk",
    "applications"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tensorlakeai/tensorlake",
    "directory": "typescript"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "undici": "8.3.0",
    "ws": "^8.20.0"
  }
}
