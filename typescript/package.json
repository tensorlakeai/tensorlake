{
  "name": "@tensorlakeai/tensorlake",
  "version": "0.1.0",
  "description": "TypeScript SDK for TensorLake Sandboxes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude tests/integration.test.ts",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "tensorlake",
    "sandbox",
    "cloud",
    "sdk"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
